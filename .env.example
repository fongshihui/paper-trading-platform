# Example environment configuration for the paper trading platform

# Kafka connection
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MARKET_DATA_TOPIC=market-data
SIGNALS_TOPIC=signals

# Simulator configuration
SLIPPAGE_BPS=5              # 5 basis points slippage
FEE_PER_TRADE=1.0           # flat fee per fill
SIMULATOR_STATE_PATH=dashboard/state.json

# Dashboard configuration
DASHBOARD_STATE_PATH=dashboard/state.json

# Market Data Producer configuration
SYMBOLS=AAPL,MSFT,GOOG,TSLA,NVDA,AMZN  # Symbols to track
PRODUCER_INTERVAL_SECS=1.0             # Seconds between price updates

# Alpaca API Configuration (for real market data)
# Get free API keys from: https://app.alpaca.markets/signup
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper trading by default
