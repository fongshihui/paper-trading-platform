# Example environment configuration for the paper trading platform

# Kafka connection
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MARKET_DATA_TOPIC=market-data
SIGNALS_TOPIC=signals

# Simulator configuration
SLIPPAGE_BPS=5              # 5 basis points slippage
FEE_PER_TRADE=1.0           # flat fee per fill
SIMULATOR_STATE_PATH=dashboard/state.json

# Dashboard configuration
DASHBOARD_STATE_PATH=dashboard/state.json
